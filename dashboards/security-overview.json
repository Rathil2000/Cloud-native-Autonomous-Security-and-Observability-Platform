{
  "title": "Security Operations Overview",
  "uid": "sec-ops-overview",
  "tags": ["security", "overview"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Active Alerts by Severity",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "count(ALERTS{alertstate='firing', severity='CRITICAL'})",
          "legendFormat": "CRITICAL"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~'5..'}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service) * 100",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "CPU Usage by Pod",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container!='POD',container!=''}[5m])) by (pod) * 100",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 4,
      "title": "Network Throughput",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum(rate(container_network_transmit_bytes_total[5m])) by (pod)",
          "legendFormat": "TX: {{ pod }}"
        },
        {
          "expr": "sum(rate(container_network_receive_bytes_total[5m])) by (pod)",
          "legendFormat": "RX: {{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "binBps"}
      }
    },
    {
      "id": 5,
      "title": "P95 Request Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service)) * 1000",
          "legendFormat": "{{ service }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 1000}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Pod Restarts",
      "type": "bargauge",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total) by (pod, namespace)",
          "legendFormat": "{{ namespace }}/{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Memory Usage by Pod",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 20},
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container!='POD',container!=''}) by (pod) / 1024 / 1024",
          "legendFormat": "{{ pod }}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "MiB"}
      }
    }
  ]
}
